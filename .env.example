# ═══════════════════════════════════════════════════════════════
# Sales Pilot — Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DB_NAME=salespilot
DB_USERNAME=salespilot
DB_PASSWORD=change-me-strong-password-here

# ─────────────────────────────────────────────────────────────
# JWT Security
# Generate a strong secret: openssl rand -base64 64
# ─────────────────────────────────────────────────────────────
JWT_SECRET=generate-a-strong-random-256-bit-secret-key-here
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# ─────────────────────────────────────────────────────────────
# Email (Resend — https://resend.com)
# ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Sales Pilot

# ─────────────────────────────────────────────────────────────
# File Storage
# Options: local | s3
# ─────────────────────────────────────────────────────────────
FILE_STORAGE_PROVIDER=local
FILE_UPLOAD_DIR=./uploads

# S3-compatible (when FILE_STORAGE_PROVIDER=s3)
# S3_BUCKET=salespilot
# S3_REGION=ap-south-1
# S3_ENDPOINT=https://your-endpoint.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ─────────────────────────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api
